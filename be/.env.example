# Copy to .env and configure before any run.

# Required: explicit opt-in for authorized red team operations
AUTHORIZED_ENGAGEMENT=false

# Engagement metadata (audit trail)
ENGAGEMENT_ID=
ENGAGEMENT_OPERATOR=

# Local JSONL audit trail for dissertation evidence
AUDIT_LOG_PATH=.runs/audit.jsonl

# Multi-host topology (YAML seed) and mutable runtime state (JSON)
ENGAGEMENT_TOPOLOGY_PATH=
ENGAGEMENT_STATE_PATH=

# Bearer token for on-host HTTP runner (remote exec)
ENGAGEMENT_RUNNER_TOKEN=

# Per-exec timeout in seconds; unset = 3600s default (long red-team commands)
BASH_TIMEOUT_SECONDS=
DEFAULT_EXEC_TIMEOUT_SECONDS=3600

# Runner listen port used during SSH bootstrap
RUNNER_PORT=8765

# Agent provider: openai or claude. Defaults to OpenAI for `uv run main.py`.
AGENT_PROVIDER=openai

# OpenAI Responses API. Required when AGENT_PROVIDER=openai.
OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=
# Optional: override the default engagement-scoped cache routing key.
OPENAI_PROMPT_CACHE_KEY=

# Anthropic Claude Messages API. Required when AGENT_PROVIDER=claude.
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=

LOG_LEVEL=INFO
