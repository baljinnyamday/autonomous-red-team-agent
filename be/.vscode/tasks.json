    },
    {
      "label": "ruff: format",
      "type": "shell",
      "command": "uv run ruff format",
      "problemMatcher": []
    },
    {
      "label": "ty: check",
      "type": "shell",
      "command": "uv run ty check",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "jsonl: pretty",
      "type": "shell",
      "command": "uv run python scripts/pretty_jsonl.py ${file}",
      "problemMatcher": []
    }
