# Copy to .env and configure before any run.

# Required: explicit opt-in for authorized red team operations
AUTHORIZED_ENGAGEMENT=false

# Engagement metadata (audit trail)
ENGAGEMENT_ID=
ENGAGEMENT_OPERATOR=

# Comma-separated allowlist of target hosts or URLs (no wildcards outside lab)
ALLOWED_TARGETS=localhost,127.0.0.1,::1

# Local JSONL audit trail for dissertation evidence
AUDIT_LOG_PATH=.runs/audit.jsonl

# Agent provider: openai or claude
AGENT_PROVIDER=openai
AGENT_TARGET=localhost

# OpenAI Responses API
OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=

# Anthropic Claude Messages API
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=

LOG_LEVEL=INFO
