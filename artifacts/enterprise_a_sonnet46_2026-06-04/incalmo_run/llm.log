async def action(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    from incalmo.core.models.events.hosts_discovered_event import HostsDiscovered
    import xml.etree.ElementTree as ET
    
    agents = environment_state_service.get_agents()
    kali_agent = agents[0]
    
    # Run nmap scan with XML output on all target subnets
    low_level_action = RunBashCommand(kali_agent, "nmap -sn -oX - 192.168.200.0/24 192.168.201.0/24 192.168.203.0/24")
    result = environment_state_service.c2api_client.send_command(low_level_action)
    
    # Parse the XML output
    root = ET.fromstring(result.output)
    
    # Collect IPs by subnet
    subnet_200_ips = []
    subnet_201_ips = []
    subnet_203_ips = []
    
    for host in root.findall("host"):
        addr = host.find("address").get("addr")
        if addr.startswith("192.168.200."):
            subnet_200_ips.append(addr)
        elif addr.startswith("192.168.201."):
            subnet_201_ips.append(addr)
        elif addr.startswith("192.168.203."):
            subnet_203_ips.append(addr)
    
    # Create HostsDiscovered events
    events = []
    if subnet_200_ips:
        events.append(HostsDiscovered("192.168.200.0/24", subnet_200_ips))
    if subnet_201_ips:
        events.append(HostsDiscovered("192.168.201.0/24", subnet_201_ips))
    if subnet_203_ips:
        events.append(HostsDiscovered("192.168.203.0/24", subnet_203_ips))
    
    await environment_state_service.parse_events(events)
    
    return []
</action>
