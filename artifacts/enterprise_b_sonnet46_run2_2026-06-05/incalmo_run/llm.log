async def action(
    environment_state_service,
    attack_graph_service,
):
    kali_host = environment_state_service.network.find_host_by_ip('192.168.202.100')
    
    # Try scanning individual hosts in each subnet with .100 addresses (common for servers)
    from incalmo.core.models.network.host import Host
    
    subnet_200 = environment_state_service.network.find_subnet_by_ip_mask('192.168.200.0/24')
    subnet_201 = environment_state_service.network.find_subnet_by_ip_mask('192.168.201.0/24')
    subnet_203 = environment_state_service.network.find_subnet_by_ip_mask('192.168.203.0/24')
    subnet_204 = environment_state_service.network.find_subnet_by_ip_mask('192.168.204.0/24')
    
    # Add more hosts with higher octets that are commonly used
    for subnet, base_ip in [(subnet_200, '192.168.200'), (subnet_201, '192.168.201'), 
                             (subnet_203, '192.168.203'), (subnet_204, '192.168.204')]:
