async def action(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    kali_host = environment_state_service.network.find_host_by_ip('192.168.202.100')
    agent = kali_host.get_agent()
    
    c2 = environment_state_service.c2api_client
    
    # Run ARP table and routing info
    cmd = RunBashCommand(agent, 'ip neigh show && ip route show && cat /proc/net/arp')
    result = c2.send_command(cmd)
    
    # Store result in a host attribute for retrieval
    kali_host.bash_output = str(result.output) if result else 'No output'
    
    return []
