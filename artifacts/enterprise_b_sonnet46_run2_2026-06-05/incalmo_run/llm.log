async def query(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    kali_host = environment_state_service.network.find_host_by_ip('192.168.202.100')
    agent = kali_host.get_agent()
    c2 = environment_state_service.c2api_client
    
    # Scan all subnets for ports 80, 8080, 4444
    cmd = RunBashCommand(agent, 
        'python3 -c "\nimport socket, concurrent.futures\n'
        'def check(ip, port):\n'
        '    try:\n'
        '        s = socket.socket()\n'
        '        s.settimeout(0.5)\n'
        '        s.connect((ip, port))\n'
        '        s.close()\n'
        '        return (ip, port)\n'
        '    except: return None\n'
        'targets = []\n'
        'for subnet in [\"192.168.200\", \"192.168.201\", \"192.168.203\", \"192.168.204\"]:\n'
        '    for i in range(1,255):\n'
        '        for port in [80, 8080, 4444]:\n'
        '            targets.append((f\"{subnet}.{i}\", port))\n'
        'with concurrent.futures.ThreadPoolExecutor(max_workers=200) as ex:\n'
        '    results = list(ex.map(lambda t: check(t[0], t[1]), targets))\n'
        'print([r for r in results if r])\n"'
    )
    result = c2.send_command(cmd)
    return result
</query>
