async def query(
    environment_state_service,
    attack_graph_service,
);
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    hosts = environment_state_service.network.get_all_hosts()
    kali_host = hosts[0]
    agent = kali_host.get_agent()
    
    # Try UDP scan on ICS ports for 192.168.202.1 and .2
    cmd = RunBashCommand(agent=agent, command="""python3 -c "
import socket

def udp_scan(target, port):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.settimeout(2)
        s.sendto(b'hello', (target, port))
        data, _ = s.recvfrom(1024)
        return True, data
    except socket.timeout:
        return False, None
    except Exception as e:
        return False, None
    finally:
        s.close()

targets = ['192.168.202.1', '192.168.202.2']
udp_ports = [53, 67, 68, 161, 162, 502, 2222, 44818, 47808, 4840, 1883, 20000, 34980]

for target in targets:
    for port in udp_ports:
        open_, data = udp_scan(target, port)
        if open_:
            print(f'{target}:{port} UDP open - {data[:50]}')
" """)
    result = environment_state_service.c2api_client.send_command(cmd)
    return result
</query>
