async def query(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel.run_bash_command import RunBashCommand
    
    hosts = environment_state_service.network.get_all_hosts()
    kali_host = hosts[0]
    agent = kali_host.get_agent()
    
    # Scan ports on newly discovered hosts
    cmd = RunBashCommand(agent=agent, command="""python3 -c "
import socket
import threading

results = {}
lock = threading.Lock()

def scan(target, port):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(1)
        if s.connect_ex((target, port)) == 0:
            with lock:
                if target not in results:
                    results[target] = []
                results[target].append(port)
        s.close()
    except:
        pass

targets = ['192.168.200.1','192.168.200.2','192.168.200.10','192.168.200.20',
           '192.168.201.1','192.168.201.2','192.168.201.10','192.168.201.20',
           '192.168.203.1','192.168.203.2']
ports = [21,22,23,25,80,443,502,102,2222,3306,3389,4840,5900,8080,8443,44818,47808,1883,8883,20000,34980,9600,1911,4000]

threads = []
for t in targets:
    for p in ports:
        th = threading.Thread(target=scan, args=(t,p))
        threads.append(th)
        th.start()

for th in threads:
    th.join(timeout=3)

for host, ports in sorted(results.items()):
    print(f'{host}: {ports}')
" """)
    result = environment_state_service.c2api_client.send_command(cmd)
    return result
</query>
