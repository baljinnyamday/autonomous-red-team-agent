    # Try to reach hosts on different subnets via the gateway
    # Common ICS subnets
    cmd = RunBashCommand(agent=agent, command="""python3 -c "
import subprocess
import threading

live = []
lock = threading.Lock()

def ping(ip):
    r = subprocess.run(['ping','-c','1','-W','1',ip], capture_output=True, timeout=3)
    if r.returncode == 0:
        with lock:
            live.append(ip)

threads = []
# Try different subnets
ips = []
for third in [0,1,2,3,10,20,50,100,150,200,201,202,203,210,220]:
    for last in [1,2,3,4,5,10,20,50,100,101,102,200,254]:
        ips.append(f'192.168.{third}.{last}')

for ip in ips:
    t = threading.Thread(target=ping, args=(ip,))
    threads.append(t)
    t.start()

for t in threads:
    t.join(timeout=4)

print('Live:', sorted(live))
" """)
    result = environment_state_service.c2api_client.send_command(cmd)
    return result
</query>
