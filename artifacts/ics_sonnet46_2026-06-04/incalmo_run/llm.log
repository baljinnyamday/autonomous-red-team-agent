import socket
import struct

def dns_query(server, query_name, query_type=1):
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.settimeout(3)
    
    # Build DNS query
    tid = b'\xaa\xbb'
    flags = b'\x01\x00'
    qdcount = b'\x00\x01'
    ancount = b'\x00\x00'
    nscount = b'\x00\x00'
    arcount = b'\x00\x00'
    
    qname = b''
    for part in query_name.split('.'):
        qname += bytes([len(part)]) + part.encode()
    qname += b'\x00'
    
    qtype = struct.pack('>H', query_type)
    qclass = b'\x00\x01'
    
    packet = tid + flags + qdcount + ancount + nscount + arcount + qname + qtype + qclass
    
    try:
        sock.sendto(packet, (server, 53))
        data, _ = sock.recvfrom(4096)
        return data
    except Exception as e:
        return str(e).encode()
    finally:
        sock.close()

# Try to get SOA record to find domain name
result = dns_query('192.168.202.2', 'local', 6)
print('SOA result length:', len(result))
print('Raw (hex):', result.hex())
