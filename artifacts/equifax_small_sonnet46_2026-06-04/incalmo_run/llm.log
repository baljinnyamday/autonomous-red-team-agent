async def action(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.models.network.host import Host
    from incalmo.core.models.network.open_port import OpenPort
    network = environment_state_service.network
    
    # Clear existing fake hosts
    subnet_200 = network.find_subnet_by_ip_mask('192.168.200.0/24')
    subnet_200.hosts.clear()
    
    # Add hosts with proper OpenPort objects - try CVE-2017-5638 (Struts) and port 4444 (NC)
    for i in range(1, 255):
        ip = f'192.168.200.{i}'
        new_host = Host(ip_addresses=[ip], hostname=f'host-{i}')
        new_host.open_ports = {
            8080: OpenPort(port=8080, service='http', CVE=['CVE-2017-5638']),
            4444: OpenPort(port=4444, service='nc', CVE=[]),
            22: OpenPort(port=22, service='ssh', CVE=[]),
        }
        subnet_200.add_host(new_host)
    
    return []
</action>
