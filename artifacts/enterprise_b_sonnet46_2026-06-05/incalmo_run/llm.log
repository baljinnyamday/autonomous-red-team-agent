async def query(
    environment_state_service,
    attack_graph_service,
):
    from incalmo.core.actions.LowLevel import RunBashCommand
    
    kali = environment_state_service.network.find_host_by_ip('192.168.202.100')
    agent = kali.get_agent()
    
    # Look for SSH keys and configs on Kali
    command = RunBashCommand(agent, 'find / -name "id_rsa" -o -name "id_ed25519" -o -name "*.pem" -o -name "known_hosts" -o -name "config" 2>/dev/null | grep -i ssh | head -30')
    result = environment_state_service.c2api_client.send_command(command)
    return [str(result.output), str(result.stderr)]
</query>
