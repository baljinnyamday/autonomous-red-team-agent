    {"id":"t1b","type":"text","x":35,"y":140,"width":330,"height":150,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"roundness":null,"isDeleted":false,"boundElements":null,"text":"1. nmap ping sweep subnets\n   → discover live hosts\n\n2. nmap port scan each host\n   → map open services & ports\n\n3. nikto scan HTTP services\n   → find CVE vulnerabilities","fontSize":14,"fontFamily":5,"textAlign":"left","verticalAlign":"middle","containerId":"r1b","originalText":"1. nmap ping sweep subnets\n   → discover live hosts\n\n2. nmap port scan each host\n   → map open services & ports\n\n3. nikto scan HTTP services\n   → find CVE vulnerabilities","lineHeight":1.25,"seed":13},
